# --- AI (OpenRouter, direct calls) ---
OPENROUTER_API_KEY=
TEACHER_MODEL=google/gemini-3.1-flash-lite        # fast chat (fallback: deepseek/deepseek-v4-flash)
ANALYZER_MODEL=openai/gpt-5                        # strong correction (fallback: anthropic/claude-sonnet-4.5)

# --- Database (Supabase / Postgres) ---
DATABASE_URL=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
ALLOWED_TELEGRAM_USER_ID=
APP_URL=

# --- Tunables (optional; defaults in lib/config/constants.ts) ---
# SESSION_IDLE_TIMEOUT_MIN=30
